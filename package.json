{
  "name": "@mobivia/design-system",
  "version": "0.1.0",
  "description": "Token-driven, AI-first Vue 3 component library for the Mobivia Group brands",
  "type": "module",
  "scripts": {
    "build:tokens": "tsx style-dictionary.config.ts",
    "dev": "vite",
    "build": "npm run build:tokens && vue-tsc --noEmit && vite build",
    "mcp": "tsx mcp/server.ts",
    "storybook": "npm run build:tokens && storybook dev -p 6009 --ci",
    "storybook:vue": "npm run build:tokens && storybook dev -p 6009 --ci",
    "storybook:react": "npm run build:tokens && storybook dev -c .storybook-react -p 6010 --ci",
    "build-storybook": "npm run build:tokens && storybook build",
    "build-storybook:vue": "npm run build:tokens && storybook build",
    "build-storybook:react": "npm run build:tokens && storybook build -c .storybook-react"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@storybook/addon-a11y": "^10.3.0",
    "@storybook/addon-docs": "^10.3.0",
    "@storybook/addon-onboarding": "^10.3.0",
    "@storybook/addon-vitest": "^10.3.0",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@storybook/vue3": "^10.3.0",
    "@storybook/vue3-vite": "^10.3.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "chromatic": "^15.3.0",
    "playwright": "^1.58.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "storybook": "^10.3.0",
    "style-dictionary": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
